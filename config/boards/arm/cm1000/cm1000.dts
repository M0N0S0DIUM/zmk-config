/dts-v1/;
#include <nordic/nrf52840_qiaa.dtsi>
#include <common/nordic/nrf52840_uf2_boot_mode.dtsi>
#include <dt-bindings/zmk/matrix_transform.h>
#include <dt-bindings/led/led.h>

#include "cm1000-pinctrl.dtsi"
#include "cm1000-layouts.dtsi"

/ {
    model = "cm1000";
    compatible = "cm1000", "nordic,nrf52840-qiaa", "nordic,nrf52840";

    chosen {
        zephyr,code-partition = &code_partition;
        zephyr,sram = &sram0;
        zephyr,flash = &flash0;
        zephyr,console = &uart0;
        zephyr,shell-uart = &uart0;
        zephyr,uart-mcumgr = &uart0;
	zmk,kscan = &kscan0;
        zmk,physical-layout = &default_layout;
        zmk,underglow = &led_strip;
	zmk,display = &nice_view;
        zephyr,display = &nice_view;
        zmk,battery = &max17048;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        diode-direction = "col2row";
        wakeup-source;

        col-gpios
            = <&gpio0 8 GPIO_ACTIVE_HIGH>,
              <&gpio0 14 GPIO_ACTIVE_HIGH>,
              <&gpio0 16 GPIO_ACTIVE_HIGH>,
              <&gpio0 17 GPIO_ACTIVE_HIGH>,
              <&gpio0 20 GPIO_ACTIVE_HIGH>,
              <&gpio0 21 GPIO_ACTIVE_HIGH>,
              <&gpio0 22 GPIO_ACTIVE_HIGH>,
              <&gpio0 24 GPIO_ACTIVE_HIGH>,
              <&gpio0 25 GPIO_ACTIVE_HIGH>,
              <&gpio0 27 GPIO_ACTIVE_HIGH>,
              <&gpio0 28 GPIO_ACTIVE_HIGH>,
              <&gpio0 29 GPIO_ACTIVE_HIGH>,
              <&gpio0 30 GPIO_ACTIVE_HIGH>,
              <&gpio0 31 GPIO_ACTIVE_HIGH>,
              <&gpio1 1 GPIO_ACTIVE_HIGH>,
              <&gpio1 2 GPIO_ACTIVE_HIGH>,
              <&gpio1 3 GPIO_ACTIVE_HIGH>;

        row-gpios
            = <&gpio1 4 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,
              <&gpio1 5 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,
              <&gpio1 6 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,
              <&gpio1 7 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,
              <&gpio1 8 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,
              <&gpio1 10 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>;
    };

    matrix_transform0: default_transform {
        compatible = "zmk,matrix-transform";
        columns = <17>;
        rows = <6>;

        map = <
            RC(0,0) RC(0,2) RC(0,3) RC(0,4) RC(0,5) RC(0,6) RC(0,7) RC(0,8) RC(0,9) RC(0,11) RC(0,12) RC(0,13) RC(0,14)
            																									   RC(0,15)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5) RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10) RC(1,11) RC(1,12) RC(1,13)  				  

             RC(2,0)  RC(2,1) RC(2,3) RC(2,4) RC(2,5) RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10) RC(2,11) RC(2,12) RC(2,13) RC(2,14)        RC(1,14) RC(2,15) RC(3,16)

               RC(3,0)   RC(3,1) RC(3,3) RC(3,4) RC(3,5) RC(3,6) RC(3,7) RC(3,8) RC(3,9) RC(3,10) RC(3,11) RC(3,12)    RC(3,13)
           																							
           	 RC(4,0)	 RC(4,2) RC(4,3) RC(4,4) RC(4,5) RC(4,6) RC(4,7) RC(4,8) RC(4,9) RC(4,10) RC(4,11) 		RC(4,13)			           RC(4,15)
          
	    RC(5,0) RC(5,1) RC(5,2) 				RC(5,6)		 			 RC(5,10) RC(5,12) RC(5,13) RC(5,14) 		      RC(5,15) RC(5,16) RC(4,16)               
        >;
    };

    leds {
        compatible = "gpio-leds";
        blue_led: led_0 {
            gpios = <&gpio0 15 GPIO_ACTIVE_HIGH>;
        };
    };

    encoder: encoder {
        compatible = "alps,ec11";
        a-gpios = <&gpio0 4 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        b-gpios = <&gpio0 5 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        steps = <20>;
        status = "okay";
    };

    sensors {
        compatible = "zmk,keymap-sensors";
        sensors = <&encoder>;
        triggers-per-rotation = <20>;
    };

    charger_iset: charger-iset {
        compatible = "gpio-leds";
        iset_10k: iset_10k {
            gpios = <&gpio0 26 GPIO_ACTIVE_LOW>;
        };
        iset_3k9: iset_3k9 {
            gpios = <&gpio1 15 GPIO_ACTIVE_LOW>;
        };
    };
};

&spi3 {
    compatible = "nordic,nrf-spim";

    pinctrl-0 = <&spi3_default>;
    pinctrl-1 = <&spi3_sleep>;
    pinctrl-names = "default", "sleep";
    status = "okay";

    led_strip: ws2812@0 {
        compatible = "worldsemi,ws2812-spi";

        /* SPI */
        reg = <0>; /* ignored, but necessary for SPI bindings */
        spi-max-frequency = <4000000>;

        /* WS2812 */
        chain-length = <82>; /* LED strip length */
        spi-one-frame = <0x70>;
        spi-zero-frame = <0x40>;
        color-mapping = <LED_COLOR_ID_GREEN LED_COLOR_ID_RED LED_COLOR_ID_BLUE>;
    };
};

&spi1 {
    compatible = "nordic,nrf-spim";
    status = "okay";
    pinctrl-0 = <&spi1_default>;
    pinctrl-1 = <&spi1_sleep>;
    pinctrl-names = "default", "sleep";
    
    /* CS Pin: P1.13 */
    cs-gpios = <&gpio1 13 GPIO_ACTIVE_HIGH>;

    nice_view: ls011b7dh03@0 {
        compatible = "sharp,ls0xx";
        reg = <0>;
        spi-max-frequency = <2000000>;
        width = <160>;
        height = <68>;
        serial-vcom-inversion;
        serial-vcom-interval = <33>;
    };
};

&uart0 {
    compatible = "nordic,nrf-uarte";
    status = "okay";
    current-speed = <115200>;
    pinctrl-0 = <&uart0_default>;
    pinctrl-1 = <&uart0_sleep>;
    pinctrl-names = "default", "sleep";
};

&flash0 {
    partitions {
        compatible = "fixed-partitions";
        #address-cells = <1>;
        #size-cells = <1>;

        sd_partition: partition@0 {
            reg = <0x00000000 0x00001000>;
        };

        code_partition: partition@1000 {
            label = "image-0";
            reg = <0x00001000 0x000d3000>;
        };

        storage_partition: partition@d4000 {
            label = "Storage";
            reg = <0x000d4000 0x00020000>;
        };

        boot_partition: partition@f4000 {
            label = "Bootloader";
            reg = <0x000f4000 0x0000c000>;
        };
    };
};


&i2c0 {
    compatible = "nordic,nrf-twim";
    status = "okay";
    pinctrl-0 = <&i2c0_default>;
    pinctrl-1 = <&i2c0_sleep>;
    pinctrl-names = "default", "sleep";

    max17048: max17048@36 {
        compatible = "zmk,maxim-max17048";
        status = "okay";
        reg = <0x36>;
    };
};
&adc { status = "okay"; };
&gpiote { status = "okay"; };
&gpio0 { status = "okay"; };
&gpio1 { status = "okay"; };

zephyr_udc0: &usbd { status = "okay"; };





